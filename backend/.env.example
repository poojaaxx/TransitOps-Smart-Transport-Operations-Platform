# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/transitops
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/transitops?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/transitops

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - the frontend origin allowed to call this API
CLIENT_URL=http://localhost:5173

# Email (nodemailer) - optional. If left blank, "sent" emails are logged
# to the console and saved to the EmailLog collection instead of actually sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TransitOps <no-reply@transitops.local>
