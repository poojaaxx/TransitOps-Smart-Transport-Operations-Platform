# MySQL connection. Works against a local MySQL Server install or a
# managed/cloud MySQL instance - just point these at whichever you're using.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=transitops
# Set to "true" for managed providers that require TLS (Aiven, PlanetScale,
# etc). Leave unset/false for a plain local MySQL install.
DB_SSL=false

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - the frontend origin allowed to call this API
CLIENT_URL=http://localhost:5173

# Email (nodemailer) - optional. If left blank, "sent" emails are logged
# to the console and saved to the EmailLog table instead of actually sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TransitOps <no-reply@transitops.local>
